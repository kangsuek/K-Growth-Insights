# K-Growth Insights environment
DATABASE_PATH=backend/data/kgrowth.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PRICE_PAGES=1
TRADING_FLOW_PAGES=1

# 네이버 검색 API(뉴스). 비워두면 뉴스 수집이 비활성화된다.
# 발급: https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NEWS_DISPLAY=10

# 자동 수집 스케줄러: 장중 N분마다 + 평일 15:40 KST 마감 수집.
SCHEDULER_ENABLED=true
COLLECT_INTERVAL_MINUTES=10
